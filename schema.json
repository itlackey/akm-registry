{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "akm Registry Index (static-index provider contract)",
  "description": "v2 JSON index schema owned by the `static-index` registry provider (v1 architecture spec §3.3). Other registry providers implement the RegistryProvider interface natively and are not required to emit this format. Static index of discoverable stashes for akm search --source registry.",
  "type": "object",
  "required": ["version", "updatedAt", "stashes"],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [3],
      "description": "Schema version. v3 introduced the wire-format clean break (`stashes[]` replacing `kits[]`); v1/v2 are not supported by akm-cli >= 0.6.0."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last index generation"
    },
    "stashes": {
      "type": "array",
      "items": { "$ref": "#/definitions/RegistryStash" }
    }
  },
  "definitions": {
    "RegistryStash": {
      "type": "object",
      "required": ["id", "name", "ref", "source"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique stable identifier, e.g. 'npm:@itlackey/your-stash' or 'github:itlackey/your-stash'"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name"
        },
        "description": {
          "type": "string",
          "description": "One-line summary for search results"
        },
        "ref": {
          "type": "string",
          "description": "Install ref passable to `akm add`, e.g. '@itlackey/your-stash' or 'itlackey/your-stash'"
        },
        "source": {
          "type": "string",
          "enum": ["npm", "github", "git", "local"],
          "description": "Registry source type"
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "URL for more information"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Searchable keywords/categories"
        },
        "assetTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["skill", "command", "agent", "knowledge", "workflow", "script", "memory", "vault", "wiki"]
          },
          "description": "What kind of stash assets this stash provides."
        },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/definitions/RegistryAsset" },
          "description": "Optional detailed asset-level metadata for v2 indexes"
        },
        "author": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "latestVersion": {
          "type": "string",
          "description": "Most recent version/tag for display"
        }
      }
    },
    "RegistryAsset": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Asset type (e.g. skill, command, agent, knowledge, workflow, script, memory, vault, wiki)"
        },
        "name": {
          "type": "string",
          "description": "Asset name"
        },
        "description": {
          "type": "string",
          "description": "One-line summary of the asset"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Searchable keywords for the asset"
        }
      }
    }
  }
}
